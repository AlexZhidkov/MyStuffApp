<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".FirstFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/text_model_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_model_missing"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <Button
            android:id="@+id/button_import_model"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/action_import_model" />

        <TextView
            android:id="@+id/text_photo_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/status_photo_missing"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <ImageView
            android:id="@+id/image_preview"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:layout_marginTop="8dp"
            android:background="@android:color/darker_gray"
            android:contentDescription="@string/photo_preview_content_description"
            android:scaleType="centerCrop" />

        <Button
            android:id="@+id/button_analyze_photo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:enabled="false"
            android:text="@string/action_analyze_photo" />

        <ProgressBar
            android:id="@+id/progress_analyzing"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/text_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/status_take_photo_first"
            android:textAppearance="?attr/textAppearanceBodyLarge" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
